{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motus.dev/schemas/handoff.schema.json",
  "title": "Motus Handoff Projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["none", "ready", "blocked"]
    },
    "receiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "agent", "service", "ci", "tool"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_action": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
