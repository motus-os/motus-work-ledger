{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motus.dev/schemas/work-event.schema.json",
  "title": "Motus Work Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "run_id",
    "seq",
    "event_kind",
    "occurred_at",
    "idempotency_key",
    "payload_hash",
    "schema_hash",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "motus.work-event.v0.1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 1
    },
    "event_kind": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "schema_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "producer_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
